# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-03-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# LLMWhisperer
LLMWHISPERER_API_KEY=your_llmwhisperer_api_key_here
LLMWHISPERER_BASE_URL=https://llmwhisperer-api.us-central.unstract.com/api/v2

# App
SQLITE_DB_PATH=./ap_invoices.db
UPLOAD_DIR=./uploads

# Langfuse observability (optional — remove or leave blank to disable)
# Sign up free at https://langfuse.com — 50K observations/month on free tier
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Use https://us.cloud.langfuse.com for US region
